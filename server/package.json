{
  "name": "project-management-server",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "JinNguyen0612",
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "build": "node scripts/generate-swagger.js && rimraf ./dist && esbuild api/index.ts --bundle --platform=node --target=node20 --outfile=api/bundle.js --external:@prisma/client --external:prisma --external:pg --external:bcrypt --external:firebase-admin --external:nodemailer --external:cloudinary --external:multer && copyfiles -u 1 \"src/infrastructure/templates/**/*\" dist/src",
    "start": "npm run build && node dist/src/server.js",
    "dev": "npm run build && concurrently \"npx tsc -w\" \"nodemon --exec ts-node src/server.ts\"",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 prisma db seed"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.4.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.2",
    "cloudinary": "^2.9.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "firebase-admin": "^13.6.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "nodemon": "^3.1.11",
    "pg": "^8.18.0",
    "rimraf": "^6.1.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ts-node": "^10.9.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.2.3",
    "@types/nodemailer": "^7.0.10",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "copyfiles": "^2.4.1",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.4",
    "jest": "^30.3.0",
    "prisma": "^7.4.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}