{
  "version": 2,
  "builds": [
    {
      "src": "api/bundle.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["prisma/**", "src/api/**/*.ts", "node_modules/swagger-ui-dist/**"]
      }
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/bundle.js"
    }
  ]
}
